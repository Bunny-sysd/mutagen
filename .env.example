# Mutagen API Key Configuration Template
# Copy this file to '.env' and fill in your keys.

# Gemini API Key (Required for default gemini provider)
GEMINI_API_KEY=your_key_here

# OpenAI API Key (Required if using --provider openai)
OPENAI_API_KEY=your_key_here

# Claude API Key (Required if using --provider claude)
CLAUDE_API_KEY=your_key_here

# Default provider configuration
MUTAGEN_PROVIDER=gemini
MUTAGEN_MODEL=gemini-2.5-flash
